{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "crons": [
    { "path": "/api/cron/events", "schedule": "0 13 * * *" },
    { "path": "/api/cron/google-ratings", "schedule": "0 5 * * 1" },
    { "path": "/api/cron/marketplace-expire", "schedule": "0 6 * * *" }
  ]
}
