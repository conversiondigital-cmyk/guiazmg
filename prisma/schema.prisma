generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// ── Enums ──────────────────────────────────────────────

enum UserRole {
  USER
  BUSINESS_OWNER
  EDITOR
  SALES_AGENT
  ADMIN
}

enum ProfileStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  INACTIVE
  REJECTED
  ARCHIVED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum BoostStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportStatus {
  PENDING
  INVESTIGATING
  RESOLVED
  DISMISSED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  CLOSED
}

enum LeadSource {
  SEARCH
  LISTING
  BOOST
  REFERRAL
  ORGANIC
  DIRECT
}

enum LeadType {
  WHATSAPP
  PHONE_CALL
  WEBSITE_VISIT
  MAP_CLICK
  WAZE_CLICK
  FORM_SUBMIT
}

enum PaymentProvider {
  MERCADO_PAGO
  STRIPE
}

enum PaymentStatus {
  PENDING
  APPROVED
  AUTHORIZED
  REJECTED
  REFUNDED
  CANCELLED
}

enum PaymentType {
  MEMBERSHIP
  BOOST
  LISTING
}

enum ProfileType {
  EMPRENDEDOR
  NEGOCIO
}

enum NotificationType {
  REVIEW
  MESSAGE
  PAYMENT
  EXPIRATION
  PROMOTION
  SYSTEM
}

enum ImportJobType {
  BUSINESSES
  CATEGORIES
  MUNICIPALITIES
  REVIEWS
  LISTINGS
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum MarketplaceListingStatus {
  ACTIVE
  SOLD
  RESERVED
  EXPIRED
  HIDDEN
  DELETED
}

enum MarketplaceListingType {
  SALE
  PURCHASE
  TRADE
  SERVICE
  REQUEST
  EVENT
  PROMOTION
}

/// ── Auth ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          UserRole  @default(USER)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  acceptedTermsAt DateTime?
  acceptedPrivacyAt DateTime?
  acceptedCommunityAt DateTime?
  sessionVersion  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  accounts         Account[]
  sessions         Session[]
   businesses       Profile[]
  reviews          Review[]
  reviewsResponded ReviewResponse[]
  reportedReports  Report[] @relation("reportedReports")
  favorites        Favorite[]
  payments         Payment[]
  leads            Lead[]
  savedSearches    SavedSearch[]
  notifications    Notification[]
  searchLogs       SearchLog[]
  auditLogs        AuditLog[]
  userSettings     UserSettings?
  salesAgent       SalesAgent?
   businessClaims   ProfileClaimRequest[]
  marketplaceListings MarketplaceListing[]
  sellerReviewsReceived SellerReview[] @relation("SellerReviews")
  sellerReviewsGiven    SellerReview[] @relation("ReviewerReviews")
  serviceRequests       ServiceRequest[]
  serviceResponses      ServiceRequestResponse[]
  billingInfo           BillingInfo?
  referralsSent         Referral[] @relation("ReferralsSent")
  referralsReceived     Referral[] @relation("ReferralsReceived")
  emailLogs             EmailLog[]
  postsAuthored         Post[] @relation("PostAuthor")
  postsReviewed         Post[] @relation("PostReviewer")

  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([lastLoginAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// ── Settings ───────────────────────────────────────────

model UserSettings {
  id                 String  @id @default(cuid())
  userId             String  @unique
  theme              String  @default("light")
  language           String  @default("es")
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)
  marketingEmails    Boolean @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

/// ── Sales ──────────────────────────────────────────────

model SalesAgent {
  id                  String   @id @default(cuid())
  userId              String   @unique
  commissionPercentage Decimal  @default(10.0) @db.Decimal(5, 2)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
   businesses Profile[]
  commissions SalesCommission[]

  @@map("sales_agents")
}

model SalesCommission {
  id            String   @id @default(cuid())
  salesAgentId  String
  businessId    String
  amount        Decimal  @db.Decimal(10, 2)
  status        String   @default("PENDING")
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  salesAgent SalesAgent @relation(fields: [salesAgentId], references: [id])
   profile   Profile   @relation(fields: [businessId], references: [id])

  @@map("sales_commissions")
}

/// ── Multi-Region ────────────────────────────────────

model Country {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // ISO 3166-1 alpha-2: MX, US, etc.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  states State[]

  @@map("countries")
}

model State {
  id        String   @id @default(cuid())
  countryId String
  name      String
  code      String   // ISO 3166-2 code without country prefix: JAL, CDMX, etc.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  country      Country @relation(fields: [countryId], references: [id])
  municipalities Municipality[]

  @@unique([countryId, code])
  @@map("states")
}

/// ── Geography ──────────────────────────────────────────

model Municipality {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  state     String   @default("Jalisco")
  stateId   String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  region      State?     @relation(fields: [stateId], references: [id])
  neighborhoods Neighborhood[]
   businesses    Profile[]
  marketplaceListings MarketplaceListing[]
  serviceRequests     ServiceRequest[]

  @@map("municipalities")
}

model Neighborhood {
  id             String   @id @default(cuid())
  municipalityId String
  name           String
  slug           String
  postalCode     String?
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  municipality Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
   businesses   Profile[]

  @@unique([municipalityId, slug])
  @@map("neighborhoods")
}

/// ── Categories & Tags ─────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subcategories Subcategory[]
   businesses    Profile[]
  listings      Listing[]

  @@map("categories")
}

model Subcategory {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  slug        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
   businesses Profile[]
  listings   Listing[]

  @@unique([categoryId, slug])
  @@map("subcategories")
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  icon      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

   businesses ProfileTag[]

  @@map("tags")
}

/// ── Profile ───────────────────────────────────────────

model Profile {
  id                String   @id @default(cuid())
  ownerId           String
  salesAgentId      String?
  categoryId        String?
  subcategoryId     String?
  municipalityId    String?
  neighborhoodId    String?
  name              String
  slug              String   @unique
  shortDescription  String?
  description       String?
  phone             String?
  whatsapp          String?
  email             String?
  websiteUrl        String?
  facebookUrl       String?
  instagramUrl      String?
  tiktokUrl         String?
  youtubeUrl        String?
  linkedinUrl       String?
  googleMapsUrl     String?
  wazeUrl           String?
  addressText       String?
  postalCode        String?
  latitude          Float?
  longitude         Float?
  logoUrl           String?
  coverImageUrl     String?
  profileType       ProfileType  @default(NEGOCIO)
  status            ProfileStatus      @default(PENDING_REVIEW)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  visibilityScore   Int                 @default(0)
  googleRating      Float?
  googleReviewCount Int?
  isVerified        Boolean             @default(false)
  isFeatured        Boolean             @default(false)
  isPremium         Boolean             @default(false)
  isActive          Boolean             @default(true)
  isDemo            Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  owner        User         @relation(fields: [ownerId], references: [id])
  salesAgent   SalesAgent?  @relation(fields: [salesAgentId], references: [id])
  category     Category?    @relation(fields: [categoryId], references: [id])
  subcategory  Subcategory? @relation(fields: [subcategoryId], references: [id])
  municipality Municipality? @relation(fields: [municipalityId], references: [id])
  neighborhood Neighborhood? @relation(fields: [neighborhoodId], references: [id])

   images              ProfileImage[]
   tags                ProfileTag[]
   hours               ProfileHour[]
   memberships         ProfileMembership[]
  listings            Listing[]
  boosts              Boost[]
  coupons             Coupon[]
  reviews             Review[]
  reviewsResponded ReviewResponse[]
  favorites           Favorite[]
  reports             Report[] @relation("profileReports")
  leads               Lead[]
  leadEvents          LeadEvent[]
   analyticsDaily      ProfileAnalyticsDaily[]
  payments            Payment[]
  commissions         SalesCommission[]
   badges              ProfileBadge[]
  referrerReferrals   Referral[] @relation("ReferrerProfile")
  referredReferrals   Referral[] @relation("ReferredProfile")
   claimRequests       ProfileClaimRequest[]

  @@index([name])
  @@index([slug])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([municipalityId])
  @@index([neighborhoodId])
  @@index([latitude, longitude])
  @@index([status])
  @@index([verificationStatus])
  @@index([isDemo])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("businesses")
}

model ProfileImage {
  id        String   @id @default(cuid())
  businessId String
  imageUrl  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

   profile Profile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_images")
}

model ProfileTag {
  id         String   @id @default(cuid())
  businessId String
  tagId      String
  createdAt  DateTime @default(now())

   profile Profile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id])

  @@unique([businessId, tagId])
  @@map("business_tags")
}

model ProfileHour {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  Int
  opensAt    String?
  closesAt   String?
  isClosed   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

   profile Profile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
  @@map("business_hours")
}

/// ── Memberships ────────────────────────────────────────

model MembershipPlan {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String?
  monthlyPrice     Decimal  @db.Decimal(10, 2)
  priorityLevel    Int      @default(0)
  maxListings      Int      @default(1)
  maxGalleryImages Int      @default(5)
  hasFeaturedBadge Boolean  @default(false)
  hasSocialLinks   Boolean  @default(false)
  hasWebsiteLink   Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

   memberships ProfileMembership[]

  @@map("membership_plans")
}

model ProfileMembership {
  id                    String   @id @default(cuid())
  businessId            String   @unique
  planId                String
  provider              PaymentProvider
  providerSubscriptionId String?
  status                String   @default("ACTIVE")
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

   profile Profile       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan     MembershipPlan @relation(fields: [planId], references: [id])

  @@map("business_memberships")
}

/// ── Listings ───────────────────────────────────────────

model Listing {
  id              String        @id @default(cuid())
  businessId      String
  categoryId      String
  subcategoryId   String?
  title           String
  slug            String
  description     String?
  price           Decimal?      @db.Decimal(10, 2)
  status          ListingStatus @default(DRAFT)
  startsAt        DateTime?
  endsAt          DateTime?
  visibilityScore Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

   profile    Profile    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category    Category    @relation(fields: [categoryId], references: [id])
  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id])

  images       ListingImage[]
  boosts       Boost[]
  leads        Lead[]
  leadEvents   LeadEvent[]
  reports      Report[]

  @@unique([businessId, slug])
  @@index([slug])
  @@index([businessId])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("listings")
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  imageUrl  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_images")
}

/// ── Boosts ─────────────────────────────────────────────

model Boost {
  id           String      @id @default(cuid())
  businessId   String
  listingId    String?
  paymentId    String?     @unique
  pricePaid    Decimal?    @db.Decimal(10, 2)
  priorityScore Int        @default(0)
  startsAt     DateTime
  endsAt       DateTime
  status       BoostStatus @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

   profile Profile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  listing  Listing? @relation(fields: [listingId], references: [id])
  payment  Payment? @relation(fields: [paymentId], references: [id])

  @@index([businessId])
  @@index([listingId])
  @@index([status])
  @@index([startsAt])
  @@index([createdAt])
  @@map("boosts")
}

/// ── Coupons ────────────────────────────────────────────

model Coupon {
  id          String   @id @default(cuid())
  businessId  String
  title       String
  description String?
  code        String?
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

   profile Profile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([isActive])
  @@index([createdAt])
  @@map("coupons")
}

/// ── Boost Definitions ──────────────────────────────

model BoostDefinition {
  id          String   @id @default(cuid())
  name        String
  durationDays Int
  price        Decimal  @db.Decimal(10, 2)
  priorityBonus Int    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("boost_definitions")
}

/// ── Promotion Coupons ──────────────────────────────

model PromotionCoupon {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String?
  discountType  String    // "PERCENTAGE" or "FIXED"
  discountValue Decimal   @db.Decimal(10, 2)
  minAmount     Decimal?  @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int       @default(0)
  startsAt      DateTime?
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("promotion_coupons")
}

/// ── Referrals ──────────────────────────────────────

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String?
  code        String
  type        String   @default("USER") // "USER", "BUSINESS"
  status      String   @default("PENDING") // PENDING, CONVERTED, REWARDED
  rewardType  String?  // "DISCOUNT", "MONTHS_FREE", "BONUS"
  rewardValue Int?
  referrerBusinessId String? // for business-invites-business
  referredBusinessId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  referrer        User      @relation("ReferralsSent", fields: [referrerId], references: [id])
  referred        User?     @relation("ReferralsReceived", fields: [referredId], references: [id])
  referrerBusiness Profile? @relation("ReferrerProfile", fields: [referrerBusinessId], references: [id])
  referredBusiness Profile? @relation("ReferredProfile", fields: [referredBusinessId], references: [id])

  @@unique([code])
  @@map("referrals")
}

/// ── Billing Info (Future CFDI) ─────────────────────

model BillingInfo {
  id                  String   @id @default(cuid())
  userId              String   @unique
  rfc                 String?
  businessName        String?
  cfdiUsage           String?
  taxRegime           String?
  taxPostalCode       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("billing_info")
}

model Review {
  id         String       @id @default(cuid())
  businessId String
  userId     String
  rating     Int
  title      String?
  comment    String?
  status     ReviewStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

   profile Profile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  response ReviewResponse?
  @@unique([businessId, userId])
  @@index([businessId])
  @@index([status, createdAt])
  @@map("reviews")
}

model ReviewResponse {
  id         String   @id @default(cuid())
  reviewId   String   @unique
  businessId String
  userId     String?
  response   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  review   Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
   profile Profile @relation(fields: [businessId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  @@index([businessId])
  @@index([userId])
  @@map("review_responses")
}

/// ── Favorites & Reports ────────────────────────────────

model Favorite {
  id                   String             @id @default(cuid())
  userId               String
  businessId           String?
  marketplaceListingId String?
  createdAt            DateTime           @default(now())

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
   profile          Profile?           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  marketplaceListing MarketplaceListing? @relation(fields: [marketplaceListingId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@unique([userId, marketplaceListingId])
  @@map("favorites")
}

model Report {
  id             String       @id @default(cuid())
  reporterUserId String
  businessId     String?
  listingId      String?
  reason         String
  description    String?
  status         ReportStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user     User      @relation("reportedReports", fields: [reporterUserId], references: [id])
  profile Profile? @relation("profileReports", fields: [businessId], references: [id])
  listing  Listing?  @relation(fields: [listingId], references: [id])

  @@index([status, createdAt])
  @@index([businessId])
  @@index([listingId])
  @@index([reporterUserId])
  @@map("reports")
}

/// ── Claims ─────────────────────────────────────────────

model ProfileClaimRequest {
  id            String   @id @default(cuid())
  userId        String
  businessId    String?
  businessName  String
  businessUrl   String?
  googleMapsUrl String?
  message       String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
   profile Profile? @relation(fields: [businessId], references: [id])

  @@index([userId])
  @@index([businessId])
  @@index([status])
  @@index([createdAt])
  @@map("business_claim_requests")
}

/// ── Payments ───────────────────────────────────────────

model Payment {
  id                String         @id @default(cuid())
  userId            String
  businessId        String?
  provider          PaymentProvider
  providerPaymentId String?        @unique
  type              PaymentType
  amount            Decimal        @db.Decimal(10, 2)
  currency          String         @default("MXN")
  status            PaymentStatus  @default(PENDING)
  metadata          Json?
  processedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id])
   profile Profile? @relation(fields: [businessId], references: [id])
  boost    Boost?

  @@index([businessId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

/// ── Leads ──────────────────────────────────────────────

model Lead {
  id         String     @id @default(cuid())
  businessId String
  userId     String?
  listingId  String?
  type       LeadType
  source     LeadSource
  status     LeadStatus  @default(NEW)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

   profile  Profile    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user      User?       @relation(fields: [userId], references: [id])
  listing   Listing?    @relation(fields: [listingId], references: [id])

  @@index([businessId])
  @@map("leads")
}

model LeadEvent {
  id         String   @id @default(cuid())
  businessId String
  listingId  String?
  eventType  String
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime @default(now())

   profile Profile  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  listing  Listing?  @relation(fields: [listingId], references: [id])

  @@map("lead_events")
}

/// ── Analytics ──────────────────────────────────────────

model ProfileAnalyticsDaily {
  id             String   @id @default(cuid())
  businessId     String
  date           DateTime
  views          Int      @default(0)
  listingViews   Int      @default(0)
  whatsappClicks Int      @default(0)
  phoneClicks    Int      @default(0)
  websiteClicks  Int      @default(0)
  facebookClicks Int      @default(0)
  instagramClicks Int     @default(0)
  tiktokClicks   Int      @default(0)
  mapClicks      Int      @default(0)
  wazeClicks     Int      @default(0)
  couponViews    Int      @default(0)
  couponRedeems  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

   profile Profile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
  @@map("business_analytics_daily")
}

/// ── Search ─────────────────────────────────────────────

model SearchLog {
  id             String   @id @default(cuid())
  query          String
  municipality   String?
  neighborhood   String?
  userId         String?
  resultsCount   Int      @default(0)
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([query])
  @@index([createdAt])
  @@map("search_logs")
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  query     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_searches")
}

/// ── SEO ────────────────────────────────────────────────

model SeoLandingPage {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  metaDescription String?
  content        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("seo_landing_pages")
}

/// ── System ─────────────────────────────────────────────

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  isSecret    Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

/// ── Audit ──────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  entityType  String
  entityId    String?
  oldValue    String?
  newValue    String?
  createdAt   DateTime @default(now())

  actor User @relation(fields: [actorUserId], references: [id])

  @@index([createdAt])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}

/// ── Notifications ──────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String?
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

/// Visitas de entrada al sitio (1 por sesión) para analítica de fuentes de tráfico.
model PageVisit {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  channel   String // DIRECT | ORGANIC | SOCIAL | REFERRAL | CAMPAIGN
  source    String? // dominio del referrer o utm_source
  medium    String? // utm_medium
  campaign  String? // utm_campaign
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([channel])
  @@map("page_visits")
}

/// ── Email Queue ────────────────────────────────────────

model EmailQueue {
  id        String       @id @default(cuid())
  toEmail   String
  subject   String
  body      String
  status    EmailStatus  @default(PENDING)
  sentAt    DateTime?
  createdAt DateTime     @default(now())

  @@map("email_queue")
}

/// ── Import Jobs ────────────────────────────────────────

model ImportJob {
  id          String          @id @default(cuid())
  type        ImportJobType
  fileName    String
  status      ImportJobStatus @default(PENDING)
  processedRows Int           @default(0)
  failedRows  Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("import_jobs")
}

/// ── Marketplace ──────────────────────────────────────────

model MarketplaceCategory {
  id           String              @id @default(cuid())
  name         String
  slug         String              @unique
  description  String?
  icon         String?
  sortOrder    Int                 @default(0)
  isActive     Boolean             @default(true)
  parentId     String?
  parent       MarketplaceCategory? @relation("MarketplaceCategoryParent", fields: [parentId], references: [id])
  children     MarketplaceCategory[] @relation("MarketplaceCategoryParent")
  listings        MarketplaceListing[]
  serviceRequests ServiceRequest[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("marketplace_categories")
}

model MarketplaceListing {
  id            String                     @id @default(cuid())
  title         String
  slug          String                     @unique
  description   String?
  price         Decimal?                   @db.Decimal(10, 2)
  type          MarketplaceListingType     @default(SALE)
  status        MarketplaceListingStatus   @default(ACTIVE)
  categoryId    String
  category      MarketplaceCategory        @relation(fields: [categoryId], references: [id])
  userId        String
  user          User                       @relation(fields: [userId], references: [id])
  municipalityId String?
  municipality  Municipality?              @relation(fields: [municipalityId], references: [id])
  neighborhood  String?
  phone         String?
  whatsapp      String?
  contactEmail  String?
  isBoosted     Boolean                    @default(false)
  boostExpiresAt DateTime?
  views         Int                        @default(0)
  whatsappClicks Int                       @default(0)
  phoneClicks   Int                        @default(0)
  favoriteCount Int                        @default(0)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  deletedAt     DateTime?

  images      MarketplaceImage[]
  favorites   Favorite[]
  sellerReviews SellerReview[]

  @@index([categoryId])
  @@index([userId])
  @@index([municipalityId])
  @@index([status])
  @@index([createdAt])
  @@map("marketplace_listings")
}

model MarketplaceImage {
  id         String             @id @default(cuid())
  listingId  String
  listing    MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url        String
  sortOrder  Int                @default(0)
  createdAt  DateTime           @default(now())

  @@map("marketplace_images")
}

model SellerReview {
  id          String   @id @default(cuid())
  sellerId    String
  seller      User     @relation("SellerReviews", fields: [sellerId], references: [id])
  reviewerId  String
  reviewer    User     @relation("ReviewerReviews", fields: [reviewerId], references: [id])
  listingId   String?
  listing     MarketplaceListing? @relation(fields: [listingId], references: [id])
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([sellerId, reviewerId, listingId])
  @@map("seller_reviews")
}

model ServiceRequest {
  id            String   @id @default(cuid())
  title         String
  description   String?
  categoryId    String?
  category      MarketplaceCategory? @relation(fields: [categoryId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  municipalityId String?
  municipality  Municipality? @relation(fields: [municipalityId], references: [id])
  neighborhood  String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  responses ServiceRequestResponse[]

  @@index([status])
  @@index([createdAt])
  @@map("service_requests")
}

model ServiceRequestResponse {
  id        String   @id @default(cuid())
  requestId String
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  isBusiness Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([userId])
  @@map("service_request_responses")
}

/// ── Gamification ───────────────────────────────────────

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?  // lucide icon name
  color       String?  // hex or tailwind
  type        String   @default("BUSINESS") // "BUSINESS", "USER"
  criteria    String?  // JSON: conditions to earn
  createdAt   DateTime @default(now())

   businesses ProfileBadge[]

  @@map("badges")
}

model ProfileBadge {
  id         String   @id @default(cuid())
  businessId String
  badgeId    String
  awardedAt  DateTime @default(now())

   profile Profile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id])

  @@unique([businessId, badgeId])
  @@map("business_badges")
}

/// ── Email Automation ───────────────────────────────────

model EmailLog {
  id        String   @id @default(cuid())
  userId    String?
  to        String
  subject   String
  template  String   // welcome, renewal_reminder, boost_ended, lead, review_request, etc.
  sentAt    DateTime @default(now())
  openedAt  DateTime?
  failedAt  DateTime?

  user User? @relation(fields: [userId], references: [id])

  @@map("email_logs")
}

/// ── Blog ───────────────────────────────────────────────

enum PostStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

model Post {
  id              String     @id @default(cuid())
  authorId        String
  title           String
  slug            String     @unique
  excerpt         String?
  content         String     @db.Text
  coverImageUrl   String?    // Stored in Cloudflare R2
  category        String?
  tags            String[]
  status          PostStatus @default(DRAFT)
  readTimeMinutes Int        @default(5)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  // Moderation
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  // Featured
  isFeatured      Boolean    @default(false)
  featuredAt      DateTime?
  // Analytics
  viewCount       Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  author     User  @relation("PostAuthor",   fields: [authorId],     references: [id])
  reviewedBy User? @relation("PostReviewer", fields: [reviewedById], references: [id])

  @@index([status, publishedAt])
  @@index([slug])
  @@index([category])
  @@index([isFeatured])
  @@index([authorId])
  @@index([updatedAt])
  @@map("posts")
}

/// ── Idempotency (webhooks, payments) ────────────────────

model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String   @unique
  response  Json?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@map("idempotency_keys")
}

model WebhookEvent {
  id        String   @id @default(cuid())
  provider  String // MERCADO_PAGO | STRIPE
  eventType String?
  eventId   String? // id de la notificación del proveedor
  status    String   @default("RECEIVED") // RECEIVED | PROCESSED | ERROR
  payload   String // JSON crudo recibido
  error     String?
  createdAt DateTime @default(now())

  @@index([provider])
  @@index([status])
  @@index([createdAt])
  @@map("webhook_events")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  source    String? // origen de la suscripción (p.ej. "footer")
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

// Eventos locales (culturales, etc.). Alta manual desde el admin; preparado para
// ingesta futura por RSS/iCal (campos source/sourceUrl para deduplicar).
// Sin relación Prisma a Municipality: municipalityId es un id suelto (se resuelve
// el nombre por consulta), para que db push agregue solo esta tabla.
model Event {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  description    String?
  startAt        DateTime
  endAt          DateTime?
  venueName      String?
  addressText    String?
  municipalityId String?
  latitude       Float?
  longitude      Float?
  category       String?
  isFree         Boolean   @default(true)
  priceText      String?
  ticketUrl      String?
  sourceUrl      String?
  source         String    @default("manual")
  organizer      String?
  coverImageUrl  String?
  isPublished    Boolean   @default(true)
  isFeatured     Boolean   @default(false)
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([startAt])
  @@index([municipalityId])
  @@index([isPublished])
  @@map("events")
}
